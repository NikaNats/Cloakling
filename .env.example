# Target website for testing
TARGET_URL=https://books.toscrape.com/

# Proxy list address (free SOCKS5 list)
PROXY_URL=https://cdn.jsdelivr.net/gh/proxifly/free-proxy-list@main/proxies/protocols/socks5/data.txt
PROXY_FILE=socks5.txt

# Maximum number of proxies to try before giving up
MAX_TOTAL_ATTEMPTS=15

# Browser headless mode
HEADLESS=true

# Maximum number of profile folders to keep on disk
MAX_PROFILES_TO_KEEP=5